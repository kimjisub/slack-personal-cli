{
  "name": "slack-personal-cli",
  "version": "0.5.0",
  "description": "Session-based Slack CLI for personal accounts — no bot token or OAuth app required.",
  "type": "module",
  "license": "MIT",
  "author": "Kim Jisub",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kimjisub/slack-personal-cli.git"
  },
  "homepage": "https://github.com/kimjisub/slack-personal-cli",
  "bugs": {
    "url": "https://github.com/kimjisub/slack-personal-cli/issues"
  },
  "keywords": [
    "slack",
    "slack-cli",
    "cli",
    "macos",
    "slack-api",
    "slack-bot",
    "agent",
    "terminal",
    "messaging"
  ],
  "bin": {
    "slk": "bin/slk.js"
  },
  "files": [
    "bin/",
    "src/",
    "LICENSE",
    "README.md",
    "SKILL.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "node bin/slk.js",
    "test": "node --test",
    "test:live": "node --test tests/live-slack.test.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  }
}
